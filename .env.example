# Copy to .env and fill in. Values also settable in the Cloudflare dashboard
# (Worker → Settings → Variables) for the deployed site.

# ── Nuxt Studio (GitHub OAuth app) ──────────────────────────────────────────
STUDIO_GITHUB_CLIENT_ID=
STUDIO_GITHUB_CLIENT_SECRET=

# ── SEO (@nuxtjs/seo) ───────────────────────────────────────────────────────
# Canonical production URL — drives sitemap.xml, robots.txt and canonical tags.
NUXT_PUBLIC_SITE_URL=https://www.petanque-fouesnantaise.fr

# ── Images (R2 + Cloudflare Image Transformations) ──────────────────────────
# Public domain of the R2 bucket (ptank-images) that serves /images/**. The
# image originals are NOT bundled in the deploy (they live in /image-sources
# only to upload from), so this is REQUIRED to see images anywhere — dev
# included. In prod the edge additionally resizes them; in dev the originals
# load straight from R2.
# Example: https://img.petanque-fouesnantaise.fr  (or the r2.dev domain)
NUXT_IMAGE_R2_BASE=

# Public domain used to SERVE media that editors upload through Studio (stored
# in the same R2 bucket under the studio/ prefix, via NuxtHub blob). Normally
# the SAME value as NUXT_IMAGE_R2_BASE — one bucket, two prefixes.
S3_PUBLIC_URL=
